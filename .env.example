# Atlassian Cloud — Jira and Confluence share the same site + credentials (Basic auth).
# Generate a token at https://id.atlassian.com/manage-profile/security/api-tokens
# (CONFLUENCE_BASE_URL / CONFLUENCE_EMAIL / CONFLUENCE_API_TOKEN are accepted as fallbacks,
#  so an .env from the ai-game-whole-game-pipeline project works unchanged.)
ATLASSIAN_BASE_URL=https://your-site.atlassian.net
ATLASSIAN_EMAIL=you@example.com
ATLASSIAN_API_TOKEN=

# Anthropic
ANTHROPIC_API_KEY=

# Optional: override the model used for drafting (default: claude-opus-4-8)
# AJT_MODEL=claude-opus-4-8
